    <script>
      const triggers = document.querySelectorAll('[data-trigger]');
      const holdItems = document.querySelectorAll('.hold-item');
      let current = 0;

      function setActive(index) {
        if (index === current) return;
        holdItems.forEach(el => el.classList.remove('active'));
        holdItems[index]?.classList.add('active');
        current = index;
      }

      const observer = new IntersectionObserver((entries) => {
        // Find the highest trigger index currently visible
        let highest = 0;
        triggers.forEach(el => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.5) {
            const idx = parseInt(el.getAttribute('data-trigger'));
            if (idx > highest) highest = idx;
          }
        });
        setActive(highest);
      }, { threshold: 0 });

      // Observe all triggers plus use scroll for real-time updates
      triggers.forEach(el => observer.observe(el));

      window.addEventListener('scroll', () => {
        let highest = 0;
        triggers.forEach(el => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight * 0.5) {
            const idx = parseInt(el.getAttribute('data-trigger'));
            if (idx > highest) highest = idx;
          }
        });
        setActive(highest);
      }, { passive: true });
    </script>

