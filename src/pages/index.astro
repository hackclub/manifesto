---
import Hero from '../components/Hero.svelte';
import { APPLY_URL } from '../config';

const DEADLINE = new Date('2026-03-20T23:59:59');
const daysRemaining = Math.max(0, Math.ceil((DEADLINE.getTime() - Date.now()) / 86400000));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Hacker Manifesto</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload fonts -->
    <link rel="preload" as="font" href="/Glyseric.woff2" type="font/woff2" crossorigin />
    <!-- Preload the most visible hero images -->
    <link rel="preload" as="image" href="/hero/01.webp" type="image/webp" />
    <link rel="preload" as="image" href="/hero/11.webp" type="image/webp" />
    <link rel="preload" as="image" href="/hero/04.webp" type="image/webp" />
    <link rel="preload" as="image" href="/hero/flag.svg" type="image/svg+xml" />
    <!-- Preload Young Serif font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anonymous+Pro:wght@700&family=Inter:ital,wght@0,400;1,400&family=Jua&family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=PT+Serif:ital,wght@0,700;1,400&family=Young+Serif&display=swap" rel="stylesheet" />

    <style>
      @font-face {
        font-family: 'Phantom Sans';
        src: url('https://assets.hackclub.com/fonts/Phantom_Sans_0.7/Regular.woff2') format('woff2'),
             url('https://assets.hackclub.com/fonts/Phantom_Sans_0.7/Regular.woff') format('woff');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }
      *, *::before, *::after { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      html, body { margin: 0; padding: 0; background: #1c1c1a; }
    </style>
  </head>
  <body>
    <Hero client:load applyUrl={APPLY_URL} />

    <section class="programs">
      <h2 class="programs-headline">
        In the past year, gap years have run programs<br>with over <span class="red">10,000+ real users </span>
      </h2>

      <div class="programs-grid">
        <a class="program-card" href="https://flagship.hackclub.com" target="_blank" rel="noopener">
          <img class="program-card-img" src="/images/campfire-flagship.png" alt="Campfire Flagship" />
          <img class="program-card-logo" src="/images/campfire-flagship-logo.png" alt="Campfire Flagship logo" />
          <p class="program-card-desc">A 3 day flagship game jam in Los Angeles with YouTubers like Michael Reeves, William Osman, and many more!</p>
        </a>

        <a class="program-card" href="https://midnight.hackclub.com" target="_blank" rel="noopener">
          <img class="program-card-img" src="/images/midnight.jpg" alt="Midnight" />
          <div class="midnight-logo">
            <img class="front" src="/images/midnight-logo.svg" alt="Midnight logo" />
          </div>
          <p class="program-card-desc">A murder-mystery hackathon held in Austria, Vienna with 60+ teenagers from all across the world!</p>
        </a>

        <a class="program-card" href="https://blueprint.hackclub.com" target="_blank" rel="noopener">
          <img class="program-card-img" src="/images/blueprint.png" alt="Blueprint" />
          <img class="program-card-logo" src="/images/blueprint-logo.png" alt="Blueprint logo" style="width:300px" />
          <p class="program-card-desc">From October 2025 to March 2026, Blueprint gave $140,000 to fund 1,500 hardware and electronics projects built by 1000 teenagers from 77 countries</p>
        </a>

        <a class="program-card" href="https://siege.hackclub.com" target="_blank" rel="noopener">
          <img class="program-card-img" src="/images/siege.png" alt="Siege" />
          <img class="program-card-logo" src="/images/siege-logo.png" alt="Siege logo" style="width:161px" />
          <p class="program-card-desc">A 14 week event where 250 teens created a project each week to work towards a laptop with over 100 framework laptops given out.</p>
        </a>
      </div>

      <div class="programs-more">
        <h3 class="programs-more-title">...and so much more...</h3>
        <div class="programs-more-grid">
          <a class="mini-card" href="https://summer.hackclub.com" target="_blank" rel="noopener" style="background-image:url('/images/summer-of-making.png');background-size:cover;background-position:bottom">
            <img class="mini-card-logo" src="/images/som-logo.png" alt="Summer of Making" style="width:60%;height:auto" />
          </a>

          <a class="mini-card" href="https://campfire.hackclub.com" target="_blank" rel="noopener">
            <img class="mini-card-bg" src="/images/campfire-bg.png" alt="" />
            <img class="mini-card-logo" src="/images/campfire-logo.png" alt="Campfire" style="width:65%;height:auto" />
          </a>

          <a class="mini-card" href="https://sleepover.hackclub.com" target="_blank" rel="noopener" style="background-color:#dbdcf7;background-image:url('/images/sleepover-pattern.png');background-repeat:repeat;background-size:112px">
            <img class="mini-card-logo" src="/images/sleepover-logo.png" alt="Sleepover" style="width:60%;height:auto" />
          </a>

          <a class="mini-card" href="https://overglade.hackclub.com" target="_blank" rel="noopener">
            <img class="mini-card-bg" src="/images/overglade.png" alt="Overglade" />
          </a>

          <a class="mini-card" href="https://undercity.hackclub.com" target="_blank" rel="noopener" style="background:#171717">
            <img class="mini-card-bg" src="/images/undercity-bg.png" alt="" />
            <img class="mini-card-logo" src="/images/undercity-logo.png" alt="Undercity" style="width:65%;height:auto" />
          </a>

          <a class="mini-card" href="https://shiba.hackclub.com" target="_blank" rel="noopener">
            <img class="mini-card-bg" src="/images/shiba-bg.png" alt="" />
            <div class="mini-card-overlay"></div>
            <img class="mini-card-logo" src="/images/shiba-logo.png" alt="Shiba Arcade" style="width:308px;max-width:80%;height:auto;opacity:0.8;filter:drop-shadow(0 0 80px white)" />
          </a>

          <a class="mini-card" href="https://hackpad.hackclub.com" target="_blank" rel="noopener">
            <img class="mini-card-bg" src="/images/hackpad-bg.png" alt="" />
            <img class="mini-card-logo" src="/images/hackpad-logo.png" alt="Hackpad" style="width:65%;height:auto" />
          </a>

          <a class="mini-card" href="https://horizons.hackclub.com" target="_blank" rel="noopener">
            <img class="mini-card-bg" src="/images/horizons-bg.png" alt="" />
            <img class="mini-card-logo" src="/images/horizons-logo.png" alt="Horizons" style="width:100%;height:auto" />
          </a>
        </div>
      </div>
    </section>

    <section class="gapyear">
      <h2 class="gapyear-title">As a gap year...</h2>
      <div class="gapyear-col">
        <div class="gapyear-row">
          <div class="quadrant work">
            <img class="quadrant-img" src="/images/gapyear-work.png" alt="Work" />
            <p class="quadrant-desc">40 gap years get $ 8.5M to build YSWS Programs and $50K as salary for the year.</p>
          </div>
          <div class="quadrant vermont">
            <img class="quadrant-img" src="/images/gapyear-vermont.png" alt="Vermont Life" />
            <p class="quadrant-desc right">Work in person at our offices in Shelburne VT, and get to enjoy the vibrant 4 seasons of New England</p>
          </div>
        </div>
        <div class="gapyear-row">
          <div class="quadrant projects">
            <img class="quadrant-img" src="/images/gapyear-projects.png" alt="Building Projects" />
            <p class="quadrant-desc">Run programs and own GitHub repos with thousands of real world users!</p>
          </div>
          <div class="quadrant travel">
            <img class="quadrant-img" src="/images/gapyear-travel.png" alt="Travel" />
            <p class="quadrant-desc right">Travel around the world for Hack Club events<br />and go on adventures.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="teens-built">
      <h2 class="teens-built-title">This past year, Gap Years ran programs that <span class="red">helped teens build</span>...</h2>
      <div class="teens-built-grid">

        <a href="https://github.com/ading2210/doompdf" target="_blank" rel="noopener noreferrer" class="sc sc-doompdf">
          <span class="sc-stars">3.7k⭐︎</span>
          <div class="sc-inner">
            <img class="sc-doompdf-screenshot" src="/images/doompdf-screenshot.png" alt="DoomPDF screenshot" />
            <img class="sc-doompdf-logo" src="/images/doompdf-logo.svg" alt="DoomPDF" />
            <p class="sc-desc">A source port of <em>Doom</em> (1993) that runs inside a PDF document. By Allen D.</p>
          </div>
        </a>

        <a href="https://github.com/kavishdevar/librepods" target="_blank" rel="noopener noreferrer" class="sc sc-librepods">
          <span class="sc-stars sc-stars-dark">25.7k⭐︎</span>
          <div class="sc-inner sc-inner-tight">
            <img class="sc-librepods-screenshot" src="/images/librepods-screenshot.png" alt="LibrePods" />
            <img class="sc-librepods-logo" src="/images/librepods-logo.png" alt="LibrePods" />
            <p class="sc-desc sc-desc-dark">Airpods liberated from Apple's ecosystem<br>By Kavish D</p>
          </div>
        </a>

        <a href="https://github.com/VERT-sh/VERT" target="_blank" rel="noopener noreferrer" class="sc sc-vert">
          <span class="sc-stars sc-stars-dark">14.1k⭐︎</span>
          <div class="sc-inner sc-inner-med">
            <img class="sc-vert-screenshot" src="/images/vert-screenshot.png" alt="Vert screenshot" />
            <img class="sc-vert-logo" src="/images/vert-logo.png" alt="Vert" />
            <p class="sc-desc sc-desc-dark">VERT is a file conversion utility that uses WebAssembly to convert files on your device instead of a cloud.<br>By Jovann</p>
          </div>
        </a>

        <a href="https://github.com/geg-tech/biblicallyaccuratekeyboard" target="_blank" rel="noopener noreferrer" class="sc sc-bam">
          <img class="sc-bam-bg" src="/images/bam-bg.png" alt="" />
          <div class="sc-bam-gradient"></div>
          <div class="sc-inner sc-bam-inner">
            <img class="sc-bam-screenshot" src="/images/bam-screenshot.png" alt="BAM screenshot" />
            <img class="sc-bam-logo" src="/images/bam-logo.svg" alt="The Biblically Accurate Macropad" />
            <p class="sc-desc sc-bam-desc">A very macro, macropad in the form<br />of a biblically accurate angel!<br />By Alex Tran</p>
          </div>
        </a>

        <a href="https://github.com/ayessaaa/specter" target="_blank" rel="noopener noreferrer" class="sc sc-specter">
          <img class="sc-specter-gameplay" src="/images/specter-gameplay.png" alt="Specter gameplay" />
          <div class="sc-specter-info">
            <img class="sc-specter-logo" src="/images/specter-logo.png" alt="Specter" />
            <div class="sc-specter-text">
              <p>A game about a knight bravely trying to escape the cave but he is haunted by his own ghost.</p>
              <p class="sc-specter-author">By Ayessa</p>
            </div>
          </div>
        </a>

        <a href="https://github.com/Jayx2u/blind-defusal" target="_blank" rel="noopener noreferrer" class="sc sc-blind">
          <img class="sc-blind-noise" src="/images/blind-defusal-noise.png" alt="" />
          <div class="sc-inner sc-blind-inner">
            <img class="sc-blind-screenshot" src="/images/blind-defusal-screenshot.png" alt="Blind Defusal" />
            <div class="sc-blind-info">
              <img class="sc-blind-logo" src="/images/blind-defusal-logo.svg" alt="Blind Defusal" />
              <p class="sc-blind-desc">A two-player, cooperative<br />"bomb defusal" game.<br>By Joshua W</p>
            </div>
          </div>
        </a>

      </div>
    </section>

    <section class="manifesto-section">
      <div class="cta-end">
        <h2 class="cta-end-title">The door is open.</h2>
        <a class="fellowship-btn" href={APPLY_URL} target="_blank" rel="noopener noreferrer">Apply Now ({daysRemaining} days remaining)</a>
        <div class="fellowship-links">
          <a class="fellowship-link-btn" href="https://notes.deven.dev/posts/the-plan-for-hack-club-world-dominance" target="_blank" rel="noopener noreferrer">How Hack Club works ↗</a>
          <a class="fellowship-link-btn" href="/manifesto">Read the Hacker Manifesto ↗</a>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <p>&copy; 2026 <a href="https://hackclub.com" target="_blank" rel="noopener">Hack Club</a>. 501(c)(3) nonprofit (EIN: 81-2908499)</p>
      <p>Site designed with &lt;3 by Manitej Boorgu (2025 - 26 Gap Year, from Houston, TX)</p>
    </footer>

    <style>
      @font-face {
        font-family: 'Glyseric';
        src: url('/Glyseric.woff2') format('woff2');
        font-weight: normal;
        font-style: normal;
        font-display: swap;
      }

      /* Programs section */
      .programs {
        background: #1c1c1a;
        display: flex;
        flex-direction: column;
        gap: 32px;
        align-items: center;
        padding: 60px 137px 100px;
      }

      /* Headliner */
      .programs-headline {
        font-family: 'Young Serif', serif;
        font-size: 30px;
        color: #eee;
        line-height: normal;
        font-weight: normal;
        margin: 0;
        max-width: 1644px;
        width: 100%;
      }

      .programs-headline .red {
        color: #ec3750;
      }

      .programs-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 36px;
        width: 100%;
        max-width: 1644px;
      }

      .program-card {
        display: flex;
        flex-direction: column;
        gap: 24px;
        align-items: center;
        text-decoration: none;
        height: fit-content;
      }

      .program-card:hover .program-card-img {
        transform: scale(1.03);
        filter: brightness(1.1);
      }

      .program-card-img {
        width: 100%;
        height: 300px;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease, filter 0.3s ease;
      }

      .program-card-logo {
        height: 90px;
        object-fit: contain;
        filter: drop-shadow(0 0 80px rgba(255, 255, 255, 0.5));
      }

      .program-card-desc {
        font-family: 'Glyseric', 'Newsreader', sans-serif;
        font-size: 20px;
        color: #fff;
        line-height: normal;
        margin: 0;
        width: 100%;
      }

      /* Midnight logo */
      .midnight-logo {
        position: relative;
        height: 84px;
        width: 306px;
        filter: drop-shadow(0 0 80px rgba(255, 255, 255, 0.5));
      }

      .midnight-logo .oblique {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
      }

      .midnight-logo .front {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-4.26deg);
        height: 67px;
        width: 230px;
      }

      /* Additional programs */
      .programs-more {
        display: flex;
        flex-direction: column;
        gap: 20px;
        width: 100%;
        max-width: 1646px;
      }

      .programs-more-title {
        font-family: 'Young Serif', serif;
        font-size: 26px;
        color: #eee;
        line-height: normal;
        font-weight: normal;
        margin: 0;
      }

      .programs-more-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        width: 100%;
      }

      .programs-more-link {
        font-family: 'Glyseric', 'Newsreader', sans-serif;
        font-size: 20px;
        color: #aaa;
        text-decoration: none;
        transition: color 0.2s ease;
      }

      .programs-more-link:hover {
        color: #fff;
      }

      .mini-card {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        height: 150px;
        transition: transform 0.3s ease;
      }

      .mini-card:hover {
        transform: scale(1.05);
      }

      .mini-card:hover .mini-card-bg {
        filter: brightness(1.1);
      }

      .mini-card-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: filter 0.3s ease;
      }

      .mini-card-logo {
        position: relative;
        z-index: 1;
        display: block;
        object-fit: contain;
      }


      .mini-card-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
      }

      /* Gap Year Life section */
      .gapyear {
        background: #1c1c1a;
        display: flex;
        flex-direction: column;
        gap: 36px;
        align-items: center;
        padding: 0 137px 100px;
      }

      .gapyear-title {
        font-family: 'Young Serif', serif;
        font-size: 30px;
        color: #eee;
        line-height: normal;
        font-weight: normal;
        margin: 0;
        max-width: 1628px;
        width: 100%;
      }

      .gapyear-col {
        display: flex;
        flex-direction: column;
        gap: 53px;
        width: 100%;
        max-width: 1628px;
      }

      .gapyear-row {
        display: flex;
        justify-content: space-between;
        align-items: stretch;
        gap: 36px;
      }

      .quadrant {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      .quadrant.work { width: 54%; }
      .quadrant.vermont { width: 45%; }
      .quadrant.projects { width: 45%; }
      .quadrant.travel { width: 54%; align-items: flex-end; }

      .quadrant-img {
        width: 100%;
        aspect-ratio: 16 / 8;
        object-fit: cover;
        display: block;
      }

      .quadrant-desc {
        font-family: 'Glyseric', 'Newsreader', sans-serif;
        font-size: 20px;
        color: #fff;
        line-height: normal;
        margin: 0;
      }

      .quadrant-desc.right {
        text-align: right;
      }

      /* ── Teens Built section ── */
      .teens-built {
        background: #1c1c1a;
        display: flex;
        flex-direction: column;
        gap: 36px;
        padding: 0 136px 100px;
      }

      .teens-built-title {
        font-family: 'Young Serif', serif;
        font-size: 30px;
        color: #eee;
        line-height: normal;
        font-weight: normal;
        margin: 0;
      }

      .teens-built-title .red {
        color: #ec3750;
      }

      .teens-built-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 36px;
      }

      /* ── Shared card base ── */
      .sc {
        position: relative;
        overflow: hidden;
        height: 400px;
        display: block;
        text-decoration: none;
        color: inherit;
        transition: transform 0.2s ease;
      }

      .sc:hover, .sc:focus-visible {
        transform: scale(1.05);
        filter: brightness(1.1);
      }

      .sc:focus-visible {
        outline: 2px solid #fff;
        outline-offset: 2px;
      }

      .sc, .sc * {
        text-decoration: none;
      }

      .sc-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 20px;
        padding: 20px;
        height: 100%;
      }

      .sc-inner-tight { gap: 4px; }
      .sc-inner-med { gap: 8px; }

      .sc-stars {
        position: absolute;
        top: 15px;
        right: 16px;
        font-family: 'Phantom Sans', sans-serif;
        font-size: 15px;
        color: #fff;
        opacity: 0.85;
        z-index: 2;
      }

      .sc-stars-dark { color: #000; }

      .sc-desc {
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        color: #fff;
        text-align: center;
        line-height: normal;
        margin: 0;
      }

      .sc-desc-dark { color: #000; }

      /* ── DoomPDF ── */
      .sc-doompdf { background: #282828; }

      .sc-doompdf-screenshot {
        width: 301px;
        max-width: 100%;
        height: 230px;
        object-fit: cover;
        border-radius: 8px;
      }

      .sc-doompdf-logo {
        width: 197px;
        height: 50px;
        object-fit: contain;
      }

      /* ── LibrePods ── */
      .sc-librepods { background: #fff; }

      .sc-librepods-screenshot {
        width: 106px;
        height: 230px;
        object-fit: cover;
      }

      .sc-librepods-logo {
        width: 241px;
        height: 89px;
        object-fit: contain;
      }

      /* ── Vert ── */
      .sc-vert { background: #ff83fa; }

      .sc-vert-screenshot {
        width: 319px;
        max-width: 100%;
        height: 230px;
        object-fit: cover;
      }

      .sc-vert-logo {
        width: 135px;
        height: 50px;
        object-fit: contain;
      }

      /* ── BAM ── */
      .sc-bam-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .sc-bam-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 77%);
        pointer-events: none;
      }

      .sc-bam-inner {
        position: relative;
        z-index: 1;
        padding: 6px 20px;
        gap: 8px;
      }

      .sc-bam-screenshot {
        width: 288px;
        max-width: 100%;
        height: 207px;
        object-fit: cover;
        box-shadow: 0 4px 100px rgba(234,255,0,0.3);
      }

      .sc-bam-logo {
        width: 152px;
        height: 95px;
        object-fit: contain;
      }

      .sc-bam-desc {
        color: #fdd882;
        font-family: 'Jua', sans-serif;
        font-size: 16px;
      }

      /* ── Specter ── */
      .sc-specter {
        background: #222034;
        display: flex;
        flex-direction: column;
      }

      .sc-specter-gameplay {
        width: 100%;
        flex: 1;
        object-fit: cover;
        display: block;
      }

      .sc-specter-info {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 7px;
        padding: 0 20px;
        flex-shrink: 0;
        height: 135px;
      }

      .sc-specter-logo {
        width: 127px;
        height: 41px;
        object-fit: contain;
      }

      .sc-specter-text {
        font-family: 'Phantom Sans', sans-serif;
        font-size: 16px;
        color: #fff;
        text-align: center;
        line-height: 1.12;
        margin: 0;
      }

      .sc-specter-text p { margin: 0; }

      .sc-specter-author {
        font-weight: 500;
      }

